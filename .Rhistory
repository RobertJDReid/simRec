#sf = tf |> count(class, .drop = FALSE)
bd = map(fn,function(fn){
fc = read_delim(fn) |>
mutate(class = factor(event,levels = c("CO-GC","CO-terminal","NCO-GC")))
st = fc |> count(class, .drop = FALSE)
return(st)
}) |>
bind_rows()
