library(tidyverse)
knitr::opts_chunk$set(echo = TRUE)
f = list.files("test_batches/")
?list.files
f = list.files("test_batches/",pattern = "*.tsv")
?basename
?list.files
f = list.files("test_batches/",pattern = "*.tsv",full.names = TRUE)
x = read_delim(
f[1]
)
View(x)
count(x,events)
?count
x |> count(event)
table(x$event)
