map(drop) |>
bind_rows() |>
rename(x_new = e1,y_new = e2, z_new = e3)
vec = cbind(vec,planar_vec)
vec_wide = vec |>
select(diploid,colony,field,cell,new_code,object_color,obj_rank,intensity_id,
x_new,y_new,z_new) |>
#  mutate(vec_c = list(c_across(starts_with("vec")))) |>
select(-starts_with("vec_coord"),-object_color,-intensity_id) |>
pivot_wider(names_from = obj_rank,values_from = c(x_new,y_new,z_new))
View(vec_wide)
# Chunk 1: setup
library(tidyverse)
theme_set(theme_bw())
knitr::opts_chunk$set(echo = TRUE)
# Chunk 2
dirs = list.dirs(recursive = FALSE)
# One time adjustment - bad coding
#dirs = dirs[-1]
# we can also subset this directory list for testing if necessary
dirs2 = dirs[c(1,9,17,25)]
# append "totalcelldata2.csv" to paths in dirs list
file_set = map(dirs,file.path,"totalcelldata2.csv")
# Chunk 3
data_set = map(file_set,function(f){
read_csv(f,
skip=1,
col_names = c(
"color_code",
"red_location",
"yellow_location",
"blue_location",
"red_intensity",
"yellow_intensity",
"blue_intensity",
"red_gaussian",
"yellow_gaussian",
"blue_gaussian",
"RR_distance",
"YY_distance",
"BB_distance",
"RY_distance",
"RB_distance",
"YB_distance"
),
col_types = cols(
red_location = col_character(),
yellow_location = col_character(),
blue_location = col_character(),
red_intensity = col_character(),
yellow_intensity = col_character(),
blue_intensity = col_character(),
RR_distance = col_character(),
YY_distance = col_character(),
BB_distance = col_character(),
RY_distance = col_character(),
RB_distance = col_character(),
YB_distance = col_character()
)
) |>
mutate(
sample = regmatches(f,regexec("(?<=\\.\\/).+(?=_\\(reg)",f,perl = TRUE))
) |>
separate_wider_delim(cols=sample,delim = "_",
names = c("diploid","colony","field"),
too_few = "align_start") |>
rownames_to_column(var = "cell")
}) |>
list_rbind() |>
mutate(
field = if_else(is.na(field),1,as.numeric(field))
)
# Chunk 4
b_data_set = data_set #|>
#  filter(str_detect(color_code,"B$"))
# Chunk 5
m_loc = 3
m_int = 1
m_gau = 5
red_data = b_data_set |>
select(diploid,colony,field,cell,color_code,starts_with("red")) |>
mutate(n_obj = str_count(color_code,"R")) |>
filter(n_obj > 0) |>
rowwise() |>
mutate(
location = list(split(
as.numeric(unlist(str_split(red_location,"\\,"))),
rep(seq(n_obj),each=m_loc))),
intensity = list(split(
as.numeric(unlist(str_split(red_intensity,"\\,"))),
rep(seq(n_obj),each=m_int))),
gaussian = list(split(
as.numeric(unlist(str_split(red_gaussian,"\\,"))),
rep(seq(n_obj),each=m_gau))),
object_color = "red"
) |>
select(-starts_with("red")) |>
unnest_longer(col=c(location,intensity,gaussian)) |>
unnest_wider(col=c(location,gaussian),names_sep = "_") |>
rename("y" = location_1,
"x" = location_2,
"z" = location_3,
"gs_amplitude" = gaussian_1,
"gs_sigma_x"   = gaussian_2,
"gs_sigma_y"   = gaussian_3,
"gs_sigma_z"   = gaussian_4,
"gs_R2"        = gaussian_5)
yellow_data = b_data_set |>
select(diploid,colony,field,cell,color_code,starts_with("yellow")) |>
mutate(n_obj = str_count(color_code,"Y")) |>
filter(n_obj > 0) |>
rowwise() |>
mutate(
location = list(split(
as.numeric(unlist(str_split(yellow_location,"\\,"))),
rep(seq(n_obj),each=m_loc))),
intensity = list(split(
as.numeric(unlist(str_split(yellow_intensity,"\\,"))),
rep(seq(n_obj),each=m_int))),
gaussian = list(split(
as.numeric(unlist(str_split(yellow_gaussian,"\\,"))),
rep(seq(n_obj),each=m_gau))),
object_color = "yellow"
) |>
select(-starts_with("yellow")) |>
unnest_longer(col=c(location,intensity,gaussian)) |>
unnest_wider(col=c(location,gaussian),names_sep = "_") |>
rename("y" = location_1,
"x" = location_2,
"z" = location_3,
"gs_amplitude" = gaussian_1,
"gs_sigma_x"   = gaussian_2,
"gs_sigma_y"   = gaussian_3,
"gs_sigma_z"   = gaussian_4,
"gs_R2"        = gaussian_5)
blue_data = b_data_set |>
select(diploid,colony,field,cell,color_code,starts_with("blue")) |>
mutate(n_obj = str_count(color_code,"B")) |>
filter(n_obj > 0) |>
rowwise() |>
mutate(
location = list(split(
as.numeric(unlist(str_split(blue_location,"\\,"))),
rep(seq(n_obj),each=m_loc))),
intensity = list(split(
as.numeric(unlist(str_split(blue_intensity,"\\,"))),
rep(seq(n_obj),each=m_int))),
gaussian = list(split(
as.numeric(unlist(str_split(blue_gaussian,"\\,"))),
rep(seq(n_obj),each=m_gau))),
object_color = "blue"
) |>
select(-starts_with("blue")) |>
unnest_longer(col=c(location,intensity,gaussian)) |>
unnest_wider(col=c(location,gaussian),names_sep = "_") |>
rename("y" = location_1,
"x" = location_2,
"z" = location_3,
"gs_amplitude" = gaussian_1,
"gs_sigma_x"   = gaussian_2,
"gs_sigma_y"   = gaussian_3,
"gs_sigma_z"   = gaussian_4,
"gs_R2"        = gaussian_5)
micro_tidy = bind_rows(yellow_data,red_data,blue_data)
# Chunk 6
bd = b_data_set |>
#  filter(colony != "c20" | field !="2") |>
select(color_code, colony) |>
group_by(colony,color_code) |>
summarise(
count = n()
)
# Chunk 7
bd |>
ggplot(aes(x=colony,y=count,fill=color_code)) +
geom_bar(stat = "identity") +
scale_fill_viridis_d(option = "turbo")
# Chunk 8
bd = b_data_set |>
filter(colony != "c20" | field !="2") |>
select(color_code, colony) |>
group_by(colony,color_code) |>
summarise(
count = n()
)
# Chunk 9
bd |>
ggplot(aes(x=colony,y=count,fill=color_code)) +
geom_bar(stat = "identity") +
scale_fill_viridis_d(option = "turbo")
# Chunk 10
micro_tidy |>
#  filter(intensity < 1e10) |>
#  filter(colony == "c19") |>
ggplot(aes(x=gs_R2,y=gs_sigma_x + gs_sigma_y + gs_sigma_z,
colour = color_code)) +
geom_point(alpha=0.5) +
scale_y_log10() +
scale_color_viridis_d(option = "turbo") +
facet_grid(. ~ object_color) +
#  ylim(0,30) +
ggtitle("R2 vs sigma")
# Chunk 11
micro_tidy |>
#filter(intensity < 1e10) |>
#filter(colony == "c19") |>
ggplot(aes(x=object_color,y=gs_R2,colour = color_code,
size = gs_sigma_x + gs_sigma_y + gs_sigma_z)) +
geom_point(position = position_dodge(width = 0.4)) +
#  scale_y_log10() +
scale_color_viridis_d(option = "turbo") +
ggtitle("R2 of fit")
# Chunk 12
fit_tidy = micro_tidy |>
filter(gs_R2 > 0.5) |>
filter((gs_sigma_x+gs_sigma_y+gs_sigma_z)<15)
recode = fit_tidy |>
group_by(diploid,colony,field,cell) |>
summarise(
new_code = paste(unlist(str_extract(object_color,"^.")),collapse = ""),
x = mean(x),
y = mean(y)
) |>
ungroup()
# Chunk 13
rd = recode |>
filter(str_detect(new_code,"b")) |>
select(colony,new_code) |>
group_by(colony,new_code) |>
summarise(
count = n()
)
rd |>
ggplot(aes(x=colony,y=count,fill=new_code)) +
geom_bar(stat = "identity") +
scale_fill_viridis_d(option = "turbo") #+
#  facet_grid(. ~ field)
# Chunk 14
fit_recode = fit_tidy |>
left_join(
select(recode,diploid,colony,field,cell,new_code)
)
# Chunk 15
disp_colony = "c22"
disp_field = 2
fit_recode |>
filter(colony == disp_colony) |>
filter(field == disp_field) |>
#  filter(cell == 17) |>
ggplot(aes(x = x, y = y, colour = object_color)) +
scale_colour_manual(values = c("blue","red","yellow")) +
geom_point(position = position_jitterdodge(jitter.width=2,jitter.height=2)) +
coord_fixed() +
xlim(0,672) +
ylim(510,0) +
#  geom_point() +
#  scale_y_reverse() +
geom_text(data = filter(recode,colony==disp_colony,field==disp_field),
aes(x=x,y=y,label = new_code), inherit.aes = FALSE,
vjust = 1, nudge_y = -7) +
theme(
panel.background = element_rect(fill = "grey70"),
legend.position = "none"
)
